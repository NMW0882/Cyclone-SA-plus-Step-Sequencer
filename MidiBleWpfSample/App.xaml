<Application x:Class="MidiBleWpfSample.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MidiBleWpfSample.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                   TrueBrush="Green"
                                   FalseBrush="Gray"/>
        <conv:BoolToConnectTextConverter x:Key="BoolToConnectTextConverter"/>
        <conv:BoolToConnectColorConverter x:Key="BoolToConnectColorConverter"/>
        <conv:BoolToToggleConnectTextConverter x:Key="BoolToToggleConnectTextConverter" />
    </Application.Resources>
</Application>
